import { GoogleGenAI, Type } from "@google/genai";

const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY || "" });

export interface AgentResponse {
  agentName: string;
  role: string;
  content: string;
  thoughtProcess: string[];
}

export interface DataInsight {
  metric: string;
  value: string | number;
  trend: 'up' | 'down' | 'neutral';
  explanation: string;
}

/**
 * Orchestrates real-time data analysis with structured JSON output
 */
export async function analyzeData(data: any, query: string) {
  try {
    const response = await ai.models.generateContent({
      model: "gemini-3-flash-preview",
      contents: `Analyze data: ${JSON.stringify(data)}. Query: ${query}`,
      config: {
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            insights: {
              type: Type.ARRAY,
              items: {
                type: Type.OBJECT,
                properties: {
                  metric: { type: Type.STRING },
                  value: { type: Type.STRING },
                  trend: { type: Type.STRING },
                  explanation: { type: Type.STRING }
                }
              }
            },
            chartConfig: {
              type: Type.OBJECT,
              properties: {
                type: { type: Type.STRING },
                data: { type: Type.ARRAY, items: { type: Type.OBJECT } }
              }
            },
            summary: { type: Type.STRING }
          }
        }
      }
    });
    return JSON.parse(response.text);
  } catch (error) {
    console.error("Analysis Error:", error);
    return null;
  }
}

/**
 * Simulates a multi-agent reasoning chain
 */
export async function simulateMultiAgent(task: string): Promise<AgentResponse[]> {
  const agents = [
    { name: "Alpha", role: "Data Scientist", instruction: "Focus on statistical patterns." },
    { name: "Beta", role: "Strategist", instruction: "Focus on business ROI." },
    { name: "Gamma", role: "Ethicist", instruction: "Focus on bias and privacy." }
  ];

  const results: AgentResponse[] = [];
  for (const agent of agents) {
    const response = await ai.models.generateContent({
      model: "gemini-3-flash-preview",
      contents: `Task: ${task}`,
      config: {
        systemInstruction: `You are ${agent.name}, a ${agent.role}. ${agent.instruction}`,
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            content: { type: Type.STRING },
            thoughtProcess: { type: Type.ARRAY, items: { type: Type.STRING } }
          }
        }
      }
    });
    results.push({ ...JSON.parse(response.text), agentName: agent.name, role: agent.role });
  }
  return results;
}