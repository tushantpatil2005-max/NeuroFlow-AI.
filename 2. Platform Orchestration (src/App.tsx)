import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { BrainCircuit, Database, Cpu, Activity, Terminal, Play, RefreshCw } from 'lucide-react';
import { LineChart, Line, BarChart, Bar, ResponsiveContainer, Tooltip } from 'recharts';
import { analyzeData, simulateMultiAgent, AgentResponse, DataInsight } from './services/gemini';

export default function App() {
  const [activeView, setActiveView] = useState<'intelligence' | 'agents' | 'monitoring'>('intelligence');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [query, setQuery] = useState('Analyze user growth trends for the last 6 months.');
  const [insights, setInsights] = useState<DataInsight[]>([]);
  const [chartData, setChartData] = useState<any>(null);

  const runAnalysis = async () => {
    setIsAnalyzing(true);
    const result = await analyzeData(SAMPLE_DATA, query);
    if (result) {
      setInsights(result.insights);
      setChartData(result.chartConfig);
    }
    setIsAnalyzing(false);
  };

  return (
    <div className="min-h-screen flex bg-[#050505] text-zinc-300">
      {/* Sidebar */}
      <nav className="w-16 border-r border-zinc-800 bg-[#0A0A0B] flex flex-col items-center py-6 gap-8">
        <div className="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center text-white">
          <BrainCircuit className="w-6 h-6" />
        </div>
        {/* Navigation Icons... */}
      </nav>

      {/* Main Content */}
      <main className="flex-1 p-8 overflow-y-auto">
        <header className="flex justify-between items-center mb-12">
          <h1 className="text-2xl font-bold text-white tracking-tight">
            NeuroFlow <span className="text-blue-500">Intelligence</span>
          </h1>
          <div className="status-indicator flex items-center gap-2 px-3 py-1 bg-zinc-900 rounded border border-zinc-800">
            <div className="w-2 h-2 bg-emerald-500 rounded-full animate-pulse" />
            <span className="text-[10px] font-mono uppercase">System: Optimal</span>
          </div>
        </header>

        <AnimatePresence mode="wait">
          {activeView === 'intelligence' && (
            <motion.div className="grid grid-cols-12 gap-6">
              {/* Query & Insights Panel */}
              <div className="col-span-4 space-y-6">
                <div className="panel p-4 bg-[#0A0A0B] border border-zinc-800 rounded-lg">
                  <textarea 
                    value={query} 
                    onChange={(e) => setQuery(e.target.value)}
                    className="w-full h-32 bg-black border border-zinc-800 rounded p-3 font-mono text-sm"
                  />
                  <button onClick={runAnalysis} className="w-full mt-4 bg-blue-600 py-2 rounded font-bold">
                    Execute Analysis
                  </button>
                </div>
              </div>

              {/* Visualization Panel */}
              <div className="col-span-8 h-[500px] bg-[#0A0A0B] border border-zinc-800 rounded-lg p-6">
                {chartData && (
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={chartData.data}>
                      <Tooltip contentStyle={{ backgroundColor: '#000', border: 'none' }} />
